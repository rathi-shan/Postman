{
  "consumer": {
    "name": "ProductWebClient"
  },
  "interactions": [
    {
      "description": "a request for product 10",
      "providerStates": [
        {
          "name": "product with ID 10 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/products/10"
      },
      "response": {
        "body": {
          "id": "10",
          "name": "Screwdriver",
          "price": 15.5
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "ProductService"
  }
}